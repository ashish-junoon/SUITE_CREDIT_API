  "components": {
    "schemas": {
      "Address": {
        "required": [
          "City",
          "PostalCode",
          "Region",
          "StreetAddress"
        ],
        "type": "object",
        "properties": {
          "PostalCode": {
            "minLength": 1,
            "pattern": "^\\d{6}$",
            "type": "string"
          },
          "City": {
            "maxLength": 100,
            "minLength": 2,
            "type": "string"
          },
          "Region": {
            "maxLength": 100,
            "minLength": 2,
            "type": "string"
          },
          "StreetAddress": {
            "maxLength": 250,
            "minLength": 5,
            "type": "string"
          },
          "addressType": {
            "type": "string",
            "nullable": true
          },
          "addressCategoryType": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "AuthRQ": {
        "required": [
          "amsware",
          "orderid",
          "reportId",
          "transaction_id"
        ],
        "type": "object",
        "properties": {
          "transaction_id": {
            "minLength": 1,
            "type": "string"
          },
          "orderid": {
            "minLength": 1,
            "type": "string"
          },
          "reportId": {
            "minLength": 1,
            "type": "string"
          },
          "amsware": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CrifPrefillRQ": {
        "required": [
          "customerName",
          "mobile"
        ],
        "type": "object",
        "properties": {
          "customerName": {
            "minLength": 1,
            "type": "string"
          },
          "mobile": {
            "maxLength": 10,
            "minLength": 10,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "Customerinfo": {
        "required": [
          "DateOfBirth",
          "Email",
          "Gender"
        ],
        "type": "object",
        "properties": {
          "name": {
            "$ref": "#/components/schemas/Name"
          },
          "identificationNumber": {
            "$ref": "#/components/schemas/Identificationnumber"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "DateOfBirth": {
            "minLength": 1,
            "type": "string"
          },
          "phoneNumber": {
            "$ref": "#/components/schemas/Phonenumber"
          },
          "Email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "Gender": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ExperianRequest": {
        "required": [
          "Name",
          "Pan"
        ],
        "type": "object",
        "properties": {
          "Name": {
            "maxLength": 50,
            "minLength": 3,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "Pan": {
            "minLength": 1,
            "pattern": "^[A-Z]{5}[0-9]{4}[A-Z]{1}$",
            "type": "string"
          },
          "Mobile": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "FulfillOfferRQ": {
        "type": "object",
        "properties": {
          "fulfillOfferRequest": {
            "$ref": "#/components/schemas/Fulfillofferrequest"
          }
        },
        "additionalProperties": false
      },
      "Fulfillofferrequest": {
        "type": "object",
        "properties": {
          "customerInfo": {
            "$ref": "#/components/schemas/Customerinfo"
          }
        },
        "additionalProperties": false
      },
      "Identificationnumber": {
        "required": [
          "Id"
        ],
        "type": "object",
        "properties": {
          "IdentifierName": {
            "type": "string",
            "nullable": true
          },
          "Id": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "Name": {
        "required": [
          "Forename",
          "Surname"
        ],
        "type": "object",
        "properties": {
          "Forename": {
            "maxLength": 50,
            "minLength": 2,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "Surname": {
            "maxLength": 50,
            "minLength": 2,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "Phonenumber": {
        "required": [
          "Number"
        ],
        "type": "object",
        "properties": {
          "Number": {
            "minLength": 1,
            "pattern": "^[6-9]\\d{9}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "SoftPullRQ": {
        "required": [
          "first_name",
          "last_name",
          "mobile_number",
          "uid_number"
        ],
        "type": "object",
        "properties": {
          "last_name": {
            "minLength": 1,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "first_name": {
            "minLength": 1,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "uid_number": {
            "maxLength": 12,
            "minLength": 10,
            "pattern": "^[a-zA-Z0-9]*$",
            "type": "string"
          },
          "mobile_number": {
            "minLength": 1,
            "pattern": "^[6-9]\\d{9}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "SoftPullRQV1": {
        "required": [
          "aadhaar_number",
          "first_name",
          "last_name",
          "mobile_number",
          "pan_number"
        ],
        "type": "object",
        "properties": {
          "last_name": {
            "minLength": 1,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "first_name": {
            "minLength": 1,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "aadhaar_number": {
            "maxLength": 12,
            "minLength": 12,
            "pattern": "^[a-zA-Z0-9]*$",
            "type": "string"
          },
          "pan_number": {
            "maxLength": 10,
            "minLength": 10,
            "pattern": "^[a-zA-Z0-9]*$",
            "type": "string"
          },
          "mobile_number": {
            "minLength": 1,
            "pattern": "^[6-9]\\d{9}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}